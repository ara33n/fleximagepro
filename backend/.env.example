PORT=3000
FRONTEND_ORIGIN=https://fleximagepro.com
ALLOWED_ORIGINS=https://fleximagepro.com,https://www.fleximagepro.com,https://admin.fleximagepro.com
PUBLIC_BASE_URL=https://fleximagepro.com
