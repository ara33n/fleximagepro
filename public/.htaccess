Options -Indexes
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Serve existing static files (JS, CSS, images, fonts, etc.) directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# For Angular prerendered routes: serve the route's own index.html
# e.g., /compress  →  /compress/index.html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.+[^/])$ $1/index.html [L]

# Fallback: serve root index.html for any unmatched path (404 recovery)
RewriteRule ^ /index.html [L]
