Options -Indexes

# UTF-8 Charset
AddDefaultCharset UTF-8

RewriteEngine On

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.fleximagepro\.com$ [NC]
RewriteRule ^(.*)$ https://fleximagepro.com/$1 [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Serve existing static files
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Shared image links are dynamic Angular routes.
RewriteRule ^share/.+ /share/index.html [L]

# Angular prerendered routes
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.+[^/])$ $1/index.html [L]

# Fallback
RewriteRule ^ /index.html [L]
